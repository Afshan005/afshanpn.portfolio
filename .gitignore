# ============================================================
#  .gitignore — Afshan PN Portfolio
# ============================================================

# ── OS Generated Files ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Dependencies (if any added later) ────────────────────────
node_modules/
package-lock.json

# ── Environment / Secrets ────────────────────────────────────
.env
.env.local
.env.production

# ── Build artifacts ──────────────────────────────────────────
dist/
build/
.cache/
.temp/

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
*.old
